# CollabBoard — Docker Compose secrets.
# Copy this file to `.env` (same directory as docker-compose.yml) and fill in
# strong random values. `.env` is gitignored and never committed.
#
# Generate each value with:
#   openssl rand -base64 48
#
# `docker compose up` auto-loads this `.env` and injects the values into the
# server container. Without them the server refuses to boot (production secret
# guard), so compose fails fast with a clear message pointing here.

JWT_ACCESS_SECRET=replace-with-openssl-rand-base64-48
JWT_REFRESH_SECRET=replace-with-a-different-openssl-rand-base64-48
