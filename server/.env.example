# CollabBoard server environment.
# Copy to `.env` and fill in real values. `.env` is gitignored — never commit secrets.

# Runtime environment: development | test | production
NODE_ENV=development

# Port the HTTP server listens on
PORT=4000

# Comma-separated list of allowed CORS origins (client app URLs)
CORS_ORIGIN=http://localhost:5173

# Log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# MongoDB connection string (added in a later increment)
MONGODB_URI=mongodb://localhost:27017/collabboard
