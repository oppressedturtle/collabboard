# CollabBoard server environment.
# Copy to `.env` and fill in real values. `.env` is gitignored — never commit secrets.

# Runtime environment: development | test | production
NODE_ENV=development

# Port the HTTP server listens on
PORT=4000

# Comma-separated list of allowed CORS origins (client app URLs)
CORS_ORIGIN=http://localhost:5173

# Log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# MongoDB connection string (added in a later increment)
MONGODB_URI=mongodb://localhost:27017/collabboard

# --- Auth / tokens ---
# Generate strong random values for production (the server refuses to boot in
# production while these contain "change-me"). e.g. `openssl rand -base64 48`
JWT_ACCESS_SECRET=dev-access-secret-change-me-please-0123456789
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-please-0123456789
# Token lifetimes (vercel/ms format, e.g. 15m, 1h, 7d)
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
# bcrypt cost factor (8-15)
BCRYPT_ROUNDS=12

# --- Cookies ---
# Set COOKIE_SECURE=true behind HTTPS in production
COOKIE_SECURE=false
# lax | strict | none
COOKIE_SAMESITE=lax
